rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared lists: readable and writable by any member.
    // Only the owner can delete.
    match /lists/{listId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberUids;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerUid
                    && request.auth.uid in request.resource.data.memberUids;

      allow update: if request.auth != null && (
        // Existing member updating the list
        request.auth.uid in resource.data.memberUids
        ||
        // Joining: only memberUids changes and requester adds themselves
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
         && request.auth.uid in request.resource.data.memberUids)
      );

      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid;
    }
  }
}
